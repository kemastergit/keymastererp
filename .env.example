# ═══ KEYMASTER ERP - Variables de Entorno ═══
# Copiar este archivo como .env y rellenar con valores reales
# NUNCA subir .env a GitHub (ya está en .gitignore)

# Supabase
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui

# Seguridad - Salt para encriptación de PINs y firmas
# Cambia esto por una cadena aleatoria larga y única para tu negocio
VITE_SYSTEM_SALT=CAMBIAME_POR_UN_VALOR_SECRETO_UNICO
